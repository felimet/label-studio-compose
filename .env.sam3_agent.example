# SAM3 Agent Backend Configuration
#
# The agent sends candidate mask visualizations (base64 images) to an LLM for
# reasoning-based selection.  The LLM MUST support vision (multimodal) input.
# Text-only models will fail silently and fall back to standard SAM3 prompting.
#
# SAM3_AGENT_LLM_URL is used as the OpenAI SDK `base_url`.
# The SDK appends /chat/completions automatically — do NOT include it here.

# Set to true to enable SAM3 Agent features (optional; defaults to false)
SAM3_AGENT_ENABLED=false

# ── LLM endpoint ───────────────────────────────────────────────────────────────
# Any OpenAI-compatible endpoint works.  Set URL, key, and model name together.
# NOTE: SAM3_AGENT_LLM_URL is the base URL only — do NOT append /chat/completions.
#
# Self-hosted (vision models required):
#   vLLM  : SAM3_AGENT_LLM_URL=http://localhost:8000/v1
#           SAM3_AGENT_LLM_KEY=none
#           SAM3_AGENT_MODEL_NAME=meta-llama/Llama-4-Maverick-17B-128E-Instruct-FP8
#
#   Ollama (local): SAM3_AGENT_LLM_URL=http://localhost:11434/v1
#                   SAM3_AGENT_LLM_KEY=ollama
#                   SAM3_AGENT_MODEL_NAME=gemma4:e2b   # or: qwen3.6, glm-5.1, etc.
#
#   Ollama Cloud (direct, no local daemon required):
#                   SAM3_AGENT_LLM_URL=https://ollama.com/v1
#                   SAM3_AGENT_LLM_KEY=<your-ollama-api-key>   # from ollama.com account settings
#                   SAM3_AGENT_MODEL_NAME=gemma4:31b-cloud
#                   Note: verify the chosen cloud model supports vision before use;
#                         not all cloud models (e.g. qwen3-coder, deepseek-v3.1) have multimodal capability.
#
#   Ollama Cloud (via local daemon):
#                   Prerequisites: ollama signin
#                   SAM3_AGENT_LLM_URL=http://localhost:11434/v1
#                   SAM3_AGENT_LLM_KEY=<your-ollama-api-key>
#                   SAM3_AGENT_MODEL_NAME=gemma4:e2b
#
# Hosted cloud APIs:
#   OpenAI: SAM3_AGENT_LLM_URL=https://api.openai.com/v1
#           SAM3_AGENT_LLM_KEY=sk-...
#           SAM3_AGENT_MODEL_NAME=gpt-4o
#
#   Gemini: SAM3_AGENT_LLM_URL=https://generativelanguage.googleapis.com/v1beta/openai
#           SAM3_AGENT_LLM_KEY=<your-gemini-api-key>
#           SAM3_AGENT_MODEL_NAME=gemini-3.1-flash-lite-preview
#
#   Groq  : SAM3_AGENT_LLM_URL=https://api.groq.com/openai/v1
#           SAM3_AGENT_LLM_KEY=gsk_...
#           SAM3_AGENT_MODEL_NAME=llama-3.2-90b-vision-preview
#
#   DeepSeek: SAM3_AGENT_LLM_URL=https://api.deepseek.com/v1
#             SAM3_AGENT_LLM_KEY=sk-...
#             SAM3_AGENT_MODEL_NAME=deepseek-vl2
#
#   Mistral: SAM3_AGENT_LLM_URL=https://api.mistral.ai/v1
#            SAM3_AGENT_LLM_KEY=<your-mistral-api-key>
#            SAM3_AGENT_MODEL_NAME=pixtral-large-latest
#
# Anthropic Claude (no native OpenAI-compatible API — requires LiteLLM proxy):
#   1. pip install litellm
#   2. litellm --model anthropic/claude-sonnet-4-6 --port 4000
#   3. SAM3_AGENT_LLM_URL=http://localhost:4000/v1
#      SAM3_AGENT_LLM_KEY=<your-anthropic-api-key>
#      SAM3_AGENT_MODEL_NAME=anthropic/claude-sonnet-4-6
# ──────────────────────────────────────────────────────────────────────────────
SAM3_AGENT_LLM_URL=https://generativelanguage.googleapis.com/v1beta/openai
SAM3_AGENT_LLM_KEY=<your-gemini-api-key>
SAM3_AGENT_MODEL_NAME=gemini-3.1-flash-lite-preview
