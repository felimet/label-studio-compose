<!--
  SAM3 Image Segmentation — Label Studio Labeling Config
  ======================================================
  推理模式（由幾何操作觸發）:
    Box-only  : 只框選 → SAM2 幾何分割（只分割框內物件）
    Text+Box  : 文字 Submit → 再框選 → SAM3 PCS（找符合文字的類別，box 精確定位）
    Text+Point: 文字 Submit → 再點選 → SAM3 PCS mixed mode
    Point-only: 只點選 → SAM2 幾何分割

  注意：文字 Submit 本身不觸發推理，只暫存文字供下一次幾何操作使用。

  Output:
    BrushLabels: SAM3/SAM2 返回的分割遮罩 (RLE 格式)
    scores     : 每次推理後的候選 mask 分數（由 ML backend 自動填入）

  樣式說明：
    <Style> 內的配色以暗黑模式（dark background）為基準設計。
    若使用明亮模式，請自行修改 <Style> 內的顏色值（background、color、border 等）。
-->
<View>
  <Style>
    .sam3-section {
      background: #2a2a2a;
      border: 1px solid #3d3d3d;
      border-radius: 6px;
      padding: 8px 10px;
      margin-bottom: 6px;
    }
    .sam3-label span {
      font-size: 11px;
      font-weight: 600;
      color: #888;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      border-bottom: 1px dashed #555;
      cursor: help;
      position: relative;
    }
    .sam3-label span[title]:hover::after {
      content: attr(title);
      position: absolute;
      left: 0;
      top: calc(100% + 4px);
      background: #1e1e1e;
      color: #ccc;
      padding: 8px 10px;
      border-radius: 4px;
      border: 1px solid #444;
      font-size: 11px;
      font-weight: normal;
      text-transform: none;
      letter-spacing: 0;
      white-space: pre-line;
      text-align: left;
      width: 280px;
      z-index: 9999;
      box-shadow: 0 2px 8px rgba(0,0,0,0.4);
      pointer-events: none;
    }
    .sam3-scores textarea {
      font-family: monospace;
      font-size: 11px;
      color: #aaa;
      background: #1a1a1a;
    }
    /* Loading indicator while SAM3 is running */
    .lsf-main-content.lsf-requesting .sam3-hint span::after {
      content: " ⏳ Running SAM3…";
      color: #666;
      font-size: 11px;
      font-style: italic;
      text-transform: none;
      border-bottom: none;
    }
  </Style>

  <Image name="image" value="$image" zoom="true" zoomControl="true"/>

  <!-- Optional: text prompt (Submit 暫存文字，不立即觸發推理) -->
  <View className="sam3-section">
    <HyperText name="h_text" value="" className="sam3-label sam3-hint" inline="true">
      <span title="輸入概念文字後按 Submit，立即觸發推理。&#10;&#10;純文字 → SAM3 全圖偵測所有符合描述的 instance。&#10;文字 + Box / Keypoint → Text+Geo mixed mode（更精確）。&#10;不輸入文字直接框選 → 純幾何模式。">Text Prompt (optional)</span>
    </HyperText>
    <TextArea name="text_prompt" toName="image"
              placeholder="e.g. crack, spalling, rebar"
              perRegion="false" rows="1"
              maxSubmissions="1" showSubmitButton="true" editable="true"/>
  </View>

  <!-- Prompt: positive / negative keypoints -->
  <View className="sam3-section">
    <HyperText name="h_kp" value="" className="sam3-label" inline="true">
      <span title="1. 點選工具列的 auto（⚡）圖示啟用 smart 模式。&#10;2. 選 Object（正向，標記目標）&#10;   或 background（負向，標記排除區域）。&#10;3. 點擊影像上的位置，立即觸發推理。&#10;&#10;搭配 Text Prompt → Text+Geo mixed mode。">Keypoint Prompt</span>
    </HyperText>
    <KeyPointLabels name="kp" toName="image" smart="true">
      <Label value="Object"     smart="true" background="#250dd3" showInline="true"/>
      <Label value="Exclude" smart="true" background="#555555" showInline="true"/>
    </KeyPointLabels>
  </View>

  <!-- Prompt: bounding box -->
  <View className="sam3-section">
    <HyperText name="h_rect" value="" className="sam3-label" inline="true">
      <span title="1. 點選工具列的 auto（⚡）圖示啟用 smart 模式。&#10;2. 選標籤後在影像上拖拉矩形，放開即觸發推理。&#10;&#10;Object  → 正向框（告訴模型要分割這個區域）&#10;Exclude → 負向框（告訴模型排除此區域）&#10;&#10;多個框可同時使用（Object + Exclude 組合）。&#10;多框或含 Exclude → 自動走 SAM3 PCS 路徑。&#10;搭配 Text Prompt → Text+Geo mixed mode。&#10;只用 Object 單框（無文字）→ SAM2 精確幾何分割。">Box Prompt</span>
    </HyperText>
    <RectangleLabels name="rect" toName="image" smart="true">
      <Label value="Object"  background="#FFC069" showInline="true"/>
      <Label value="Exclude" background="#FF4D4F" showInline="true"/>
    </RectangleLabels>
  </View>

  <!-- Output: SAM3 segmentation mask -->
  <View className="sam3-section">
    <HyperText name="h_output" value="" className="sam3-label" inline="true">
      <span title="SAM3/SAM2 自動生成的分割遮罩（RLE 格式）。&#10;由 Keypoint 或 Box Prompt 觸發後自動填入。">Output — Segmentation Mask</span>
    </HyperText>
    <BrushLabels name="brush" toName="image" smart="true">
      <Label value="Object" background="#FFA39E"/>
    </BrushLabels>
  </View>

  <!-- Inference scores: filled by ML backend after each prediction -->
  <View className="sam3-section sam3-scores">
    <HyperText name="h_scores" value="" className="sam3-label" inline="true">
      <span title="每次推理後，ML backend 自動填入候選 mask 的分數。&#10;格式：#rank  score=0.xxxx  box=[x0,y0,x1,y1]&#10;&#10;分數越高代表模型對該 mask 的信心越強。">Inference Scores</span>
    </HyperText>
    <TextArea name="scores" toName="image"
              placeholder="Scores appear here after prediction…"
              perRegion="false" rows="3"
              maxSubmissions="1" showSubmitButton="false" editable="false"/>
  </View>

</View>
