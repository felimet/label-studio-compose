<!--
  SAM3 Image Segmentation — Label Studio Labeling Config
  ======================================================
  Prompts (用戶操作觸發 smart predict):
    - KeyPointLabels : 正向點 (Object) / 負向點 (background)
    - RectangleLabels: 矩形框 prompt
  Output:
    - BrushLabels: SAM3 返回的分割遮罩 (RLE 格式)

  TextArea note:
    輸入文字後按 Submit，再用 KeyPoint 或 Rectangle 觸發 predict。
    文字將作為 SAM3 PCS open-vocabulary 概念 prompt。
    SAM3 不可用時（SAM2 fallback）文字 prompt 會被忽略。
-->
<View>
  <Style>
    .sam3-section {
      background: #2a2a2a;
      border: 1px solid #3d3d3d;
      border-radius: 6px;
      padding: 8px 10px;
      margin-bottom: 6px;
    }
    .sam3-label span {
      font-size: 11px;
      font-weight: 600;
      color: #888;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      border-bottom: 1px dashed #555;
      cursor: help;
      position: relative;
    }
    .sam3-label span[title]:hover::after {
      content: attr(title);
      position: absolute;
      left: 0;
      top: calc(100% + 4px);
      background: #1e1e1e;
      color: #ccc;
      padding: 8px 10px;
      border-radius: 4px;
      border: 1px solid #444;
      font-size: 11px;
      font-weight: normal;
      text-transform: none;
      letter-spacing: 0;
      white-space: pre-line;
      text-align: left;
      width: 280px;
      z-index: 9999;
      box-shadow: 0 2px 8px rgba(0,0,0,0.4);
      pointer-events: none;
    }
    /* Loading indicator while SAM3 is running */
    .lsf-main-content.lsf-requesting .sam3-hint span::after {
      content: " ⏳ Running SAM3…";
      color: #666;
      font-size: 11px;
      font-style: italic;
      text-transform: none;
      border-bottom: none;
    }
  </Style>

  <Image name="image" value="$image" zoom="true" zoomControl="true"/>

  <!-- Optional: text prompt -->
  <View className="sam3-section">
    <HyperText name="h_text" value="" className="sam3-label sam3-hint" inline="true">
      <span title="輸入概念文字後按 Submit，直接觸發 SAM3 text-only predict。&#10;&#10;也可搭配 Keypoint / Box Prompt 一起使用（mixed mode）。&#10;&#10;⚠ SAM2 fallback 時文字 prompt 無效，需搭配 KP / Box。">Text Prompt (optional)</span>
    </HyperText>
    <TextArea name="text_prompt" toName="image"
              placeholder="e.g. car, person, tree"
              perRegion="false" rows="1"
              maxSubmissions="1" showSubmitButton="true" editable="true"/>
  </View>

  <!-- Output: SAM3 segmentation mask -->
  <View className="sam3-section">
    <HyperText name="h_output" value="" className="sam3-label" inline="true">
      <span title="SAM3 自動生成的分割遮罩（RLE 格式）。&#10;無需手動操作，由 Keypoint 或 Box Prompt 觸發後自動填入。">Output — Segmentation Mask</span>
    </HyperText>
    <BrushLabels name="brush" toName="image">
      <Label value="Object" background="#FFA39E"/>
    </BrushLabels>
  </View>

  <!-- Prompt: positive / negative keypoints -->
  <View className="sam3-section">
    <HyperText name="h_kp" value="" className="sam3-label" inline="true">
      <span title="1. 點選工具列的 auto（⚡）圖示啟用 smart 模式。&#10;2. 選 Object（正向，標記目標）&#10;   或 background（負向，標記排除區域）。&#10;3. 點擊影像上的位置，SAM3 自動推論遮罩。">Keypoint Prompt</span>
    </HyperText>
    <KeyPointLabels name="kp" toName="image" smart="true">
      <Label value="Object"     smart="true" background="#250dd3" showInline="true"/>
      <Label value="background" smart="true" background="#555555" showInline="true"/>
    </KeyPointLabels>
  </View>

  <!-- Prompt: bounding box -->
  <View className="sam3-section">
    <HyperText name="h_rect" value="" className="sam3-label" inline="true">
      <span title="1. 點選工具列的 auto（⚡）圖示啟用 smart 模式。&#10;2. 選 Object 標籤。&#10;3. 在影像上拖拉矩形框住目標，&#10;   SAM3 自動推論遮罩。">Box Prompt</span>
    </HyperText>
    <RectangleLabels name="rect" toName="image" smart="true">
      <Label value="Object" background="#FFC069" showInline="true"/>
    </RectangleLabels>
  </View>
</View>
