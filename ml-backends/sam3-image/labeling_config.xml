<!--
  SAM3 Image Segmentation — Label Studio Labeling Config
  ======================================================
  推理模式（由幾何操作觸發）:
    Box-only  : 只框選 → SAM2 幾何分割（只分割框內物件）
    Text+Box  : 文字 + Add → 再框選 → SAM3 PCS（找符合文字的類別，box 精確定位）
    Text+Point: 文字 + Add → 再點選 → SAM3 PCS mixed mode
    Point-only: 只點選 → SAM2 幾何分割

  注意：文字 + Add 本身不觸發混合模式推理，只暫存文字供下一次幾何操作使用。

  Output:
    BrushLabels: SAM3/SAM2 返回的分割遮罩 (RLE 格式)
    scores     : 每次推理後的候選 mask 分數（由 ML backend 自動填入）

  樣式說明：
    <Style> 內的配色以暗黑模式（dark background）為基準設計。
    若使用明亮模式，請自行修改 <Style> 內的顏色值（background、color、border 等）。
-->
<View>
  <Style>
    .sam3-section {
      background: #2a2a2a;
      border: 1px solid #3d3d3d;
      border-radius: 6px;
      padding: 8px 10px;
      margin-bottom: 6px;
    }
    .sam3-label span {
      font-size: 11px;
      font-weight: 600;
      color: #888;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      border-bottom: 1px dashed #555;
      cursor: help;
      position: relative;
    }
    .sam3-label span[title]:hover::after {
      content: attr(title);
      position: absolute;
      left: 0;
      top: calc(100% + 4px);
      background: #1e1e1e;
      color: #ccc;
      padding: 8px 10px;
      border-radius: 4px;
      border: 1px solid #444;
      font-size: 11px;
      font-weight: normal;
      text-transform: none;
      letter-spacing: 0;
      white-space: pre-line;
      text-align: left;
      width: 280px;
      z-index: 9999;
      box-shadow: 0 2px 8px rgba(0,0,0,0.4);
      pointer-events: none;
    }
    .sam3-scores textarea {
      font-family: monospace;
      font-size: 11px;
      color: #aaa;
      background: #1a1a1a;
    }
    .sam3-inline-row {
      display: flex;
      align-items: flex-end;
      gap: 10px;
      flex-wrap: wrap;
    }
    .sam3-topk-k textarea {
      max-width: 130px;
    }
    /* Loading indicator while SAM3 is running */
    .lsf-main-content.lsf-requesting .sam3-hint span::after {
      content: " ⏳ Running SAM3…";
      color: #666;
      font-size: 11px;
      font-style: italic;
      text-transform: none;
      border-bottom: none;
    }
  </Style>

  <Image name="image" value="$image" zoom="true" zoomControl="true"/>

  <!-- Pure text prompt (保留既有純文字路徑) -->
  <View className="sam3-section">
    <HyperText name="h_text_pure" value="" className="sam3-label" inline="true">
      <span title="保留既有純文字提示欄位。&#10;&#10;輸入概念文字後按 + Add，系統會記住此提示。&#10;當沒有幾何提示時，走純文字推理路徑。&#10;若有幾何提示且 mixed 欄位為空，會回退使用 pure 欄位。">Text Prompt (pure text)</span>
    </HyperText>
    <TextArea name="text_prompt" toName="image"
              placeholder="e.g. crack, spalling, rebar"
              perRegion="false" rows="1"
              maxSubmissions="1" showSubmitButton="true" editable="true"/>
  </View>

  <!-- Mixed-use text prompt (+ Add 暫存文字，不單獨觸發推理) -->
  <View className="sam3-section">
    <HyperText name="h_text_mixed" value="" className="sam3-label sam3-hint" inline="true">
      <span title="輸入概念文字後按 + Add 只會暫存文字，不會單獨觸發推理。&#10;&#10;此欄位用於混合模式（Text+Box / Text+Keypoint），且優先於 pure 欄位。&#10;若 mixed 欄位留空才會回退使用 pure 欄位。&#10;若只輸入但未送出（未按 + Add），點擊物件通常會落回 geo_only。&#10;不輸入文字直接框選 → 純幾何模式。">Text Prompt (mixed use)</span>
    </HyperText>
    <TextArea name="text_prompt_mixed" toName="image"
              placeholder="e.g. crack, spalling, rebar"
              perRegion="false" rows="1"
              maxSubmissions="1" showSubmitButton="true" editable="true"/>
  </View>

  <!-- Prompt: positive / negative keypoints -->
  <View className="sam3-section">
    <HyperText name="h_kp" value="" className="sam3-label" inline="true">
      <span title="1. 點選工具列的 auto（⚡）圖示啟用 smart 模式。&#10;2. 選 Object（正向，標記目標）&#10;   或 background（負向，標記排除區域）。&#10;3. 點擊影像上的位置，立即觸發推理。&#10;&#10;搭配 Text Prompt → Text+Geo mixed mode。">Keypoint Prompt</span>
    </HyperText>
    <KeyPointLabels name="kp" toName="image" smart="true">
      <Label value="Object"     smart="true" background="#250dd3" showInline="true"/>
      <Label value="Exclude" smart="true" background="#555555" showInline="true"/>
    </KeyPointLabels>
  </View>

  <!-- Prompt: bounding box -->
  <View className="sam3-section">
    <HyperText name="h_rect" value="" className="sam3-label" inline="true">
      <span title="1. 點選工具列的 auto（⚡）圖示啟用 smart 模式。&#10;2. 選標籤後在影像上拖拉矩形，放開即觸發推理。&#10;&#10;Object  → 正向框（告訴模型要分割這個區域）&#10;Exclude → 負向框（告訴模型排除此區域）&#10;&#10;多個框可同時使用（Object + Exclude 組合）。&#10;多框或含 Exclude → 自動走 SAM3 PCS 路徑。&#10;搭配 Text Prompt → Text+Geo mixed mode。&#10;只用 Object 單框（無文字）→ SAM2 精確幾何分割。">Box Prompt</span>
    </HyperText>
    <RectangleLabels name="rect" toName="image" smart="true">
      <Label value="Object"  background="#FFC069" showInline="true"/>
      <Label value="Exclude" background="#FF4D4F" showInline="true"/>
    </RectangleLabels>
  </View>

  <!-- Output: SAM3 segmentation mask -->
  <View className="sam3-section">
    <HyperText name="h_output" value="" className="sam3-label" inline="true">
      <span title="SAM3/SAM2 自動生成的分割遮罩（RLE 格式）。&#10;由 Keypoint 或 Box Prompt 觸發後自動填入。">Output — Segmentation Mask</span>
    </HyperText>
    <BrushLabels name="brush" toName="image" smart="true">
      <Label value="Object" background="#FFA39E"/>
    </BrushLabels>
  </View>

  <!-- Runtime confidence threshold override (optional) -->
  <View className="sam3-section">
    <HyperText name="h_threshold" value="" className="sam3-label sam3-hint" inline="true">
      <span title="可選：覆蓋後端的 SAM3_CONFIDENCE_THRESHOLD。&#10;&#10;輸入 0~1 後按 + Add，下一次推理會使用此值。&#10;留空則使用環境變數設定。&#10;超出範圍會自動夾回 0~1。&#10;&#10;右側 checkbox (apply_threshold_globally) 可覆蓋門檻套用範圍：&#10;勾選 → 所有 selection mode 套用門檻。&#10;未勾選 → 僅 threshold 模式套用門檻。">Confidence Threshold (optional)</span>
    </HyperText>
    <View className="sam3-inline-row">
      <Choices name="apply_threshold_globally" toName="image" choice="multiple" showInline="true">
        <Choice value="apply_threshold_globally" selected="true"/>
      </Choices>
      <TextArea name="confidence_threshold" toName="image"
                placeholder="e.g. 0.50 (range: 0~1)"
                perRegion="false" rows="1"
                maxSubmissions="1" showSubmitButton="true" editable="true"/>
    </View>
  </View>

  <!-- Runtime selection mode override (optional) -->
  <View className="sam3-section">
    <HyperText name="h_selection_mode" value="" className="sam3-label sam3-hint" inline="true">
      <span title="可選：覆蓋後端的 SAM3_MASK_SELECTION_MODE（勾選後立即生效於下一次推理）。&#10;&#10;模式操作說明：&#10;adaptive  → 系統依提示型態自動挑選候選數。&#10;top1      → 只回傳最高分 1 個候選。&#10;topk      → 回傳前 K 名候選（K 優先取右側 Top-K (k) 欄位；留空時用 SAM3_MAX_RETURNED_MASKS）。&#10;threshold → 只回傳分數 >= Confidence Threshold 的候選。&#10;all       → 先保留全部候選，再依門檻策略過濾。&#10;&#10;門檻策略由團隊設定決定：&#10;SAM3_APPLY_THRESHOLD_GLOBALLY=true  → 所有模式套用 Confidence Threshold。&#10;SAM3_APPLY_THRESHOLD_GLOBALLY=false → 僅 threshold 模式套用 Confidence Threshold。">Selection Mode (optional)</span>
    </HyperText>
    <View className="sam3-inline-row">
      <Choices name="selection_mode" toName="image" choice="single" showInline="true">
        <Choice value="adaptive"/>
        <Choice value="top1"/>
        <Choice value="topk"/>
        <Choice value="threshold"/>
        <Choice value="all" selected="true"/>
      </Choices>
      <TextArea name="selection_topk_k" toName="image" className="sam3-topk-k"
                placeholder="Top-K (e.g. 5)"
                perRegion="false" rows="1"
                maxSubmissions="1" showSubmitButton="true" editable="true"/>
    </View>
  </View>
  
  <!-- Inference scores: filled by ML backend after each prediction -->
  <View className="sam3-section sam3-scores">
    <HyperText name="h_scores" value="" className="sam3-label" inline="true">
      <span title="每次推理後，ML backend 自動填入候選 mask 的分數。&#10;格式：#rank  score=0.xxxx  box=[x0,y0,x1,y1]&#10;&#10;分數越高代表模型對該 mask 的信心越強。">Inference Scores</span>
    </HyperText>
    <TextArea name="scores" toName="image"
              placeholder="Scores appear here after prediction…"
              perRegion="false" rows="3"
              maxSubmissions="1" showSubmitButton="false" editable="false"/>
  </View>

</View>
