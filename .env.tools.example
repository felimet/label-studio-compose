# ============================================================
# Developer Tools Environment Template
# Scope: docker-compose.tools.yml
# Services: redisinsight (and future non-critical local tools)
#
# Usage:
#   cp .env.tools.example .env.tools
#   # Fill optional fields
# ============================================================

# ─── RedisInsight UI Exposure / Tunnel ───────────────────────
# REDISINSIGHT_PORT is the host port exposed by docker-compose.tools.yml.
# Keep REDISINSIGHT_BIND_ADDRESS=127.0.0.1 unless you intentionally expose UI to LAN.
REDISINSIGHT_VERSION=latest
REDISINSIGHT_BIND_ADDRESS=127.0.0.1
REDISINSIGHT_PORT=15540
REDISINSIGHT_CONTAINER_PORT=5540
REDISINSIGHT_APP_HOST=0.0.0.0
# REDISINSIGHT_PROXY_PATH=

# Optional built-in HTTPS key/cert (PEM path or PEM string)
# REDISINSIGHT_SERVER_TLS_KEY=
# REDISINSIGHT_SERVER_TLS_CERT=

# ─── RedisInsight Security / Logging ─────────────────────────
# Optional encryption key for local stored credentials/history.
# Keep stable if redisinsight-data volume is persisted.
REDISINSIGHT_ENCRYPTION_KEY= <openssl rand -hex 32>
REDISINSIGHT_LOG_LEVEL=info
REDISINSIGHT_STDOUT_LOGGER=true
REDISINSIGHT_FILES_LOGGER=true
REDISINSIGHT_DATABASE_MANAGEMENT=true
REDISINSIGHT_ACCEPT_TERMS_AND_CONDITIONS=true

# ─── Preconfigured Redis Connection ──────────────────────────
# These fields auto-register a default Redis connection in RedisInsight.
# By default, host/port target the internal docker service `redis:6379`.
# Password is wired from core .env REDIS_PASSWORD at compose runtime.
REDISINSIGHT_REDIS_HOST=redis
REDISINSIGHT_REDIS_PORT=6379
REDISINSIGHT_REDIS_ALIAS=label-studio-redis
REDISINSIGHT_REDIS_USERNAME=default
REDISINSIGHT_REDIS_DB=0

# Use REDIS_PASSWORD from .env by default (compose wiring).
# Enable TLS only when your Redis endpoint supports TLS.
# Common pitfall:
# - Enabling TLS=true without CA/cert/key values causes connection failures.
REDISINSIGHT_REDIS_TLS=false
# REDISINSIGHT_REDIS_TLS_CA_BASE64=
# REDISINSIGHT_REDIS_TLS_CA_PATH=
# REDISINSIGHT_REDIS_TLS_CERT_BASE64=
# REDISINSIGHT_REDIS_TLS_CERT_PATH=
# REDISINSIGHT_REDIS_TLS_KEY_BASE64=
# REDISINSIGHT_REDIS_TLS_KEY_PATH=

# Optional JSON file path for preloaded DB connections
# REDISINSIGHT_PRE_SETUP_DATABASES_PATH=
