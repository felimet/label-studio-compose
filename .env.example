# ============================================================
# Label Studio + MinIO + SAM3 — Environment Variables Template
# Copy this file to .env and fill in all <PLACEHOLDER> values.
# NEVER commit .env to version control.
# ============================================================

# ─── Image Versions ──────────────────────────────────────────
# Pin exact versions to avoid unexpected upgrades.
# Update these when you intentionally want to upgrade a service.
POSTGRES_VERSION=17
REDIS_VERSION=8.6.2
# WARNING: minio/minio repo archived 2026-02-13. No future updates — evaluate migration to R2/S3.
# NOTE: RELEASE.2025-10-15T17-29-55Z patches a privilege escalation CVE; update if security is a concern.
MINIO_VERSION=RELEASE.2025-09-07T16-13-09Z
MC_VERSION=RELEASE.2025-08-13T08-35-41Z
# Label Studio — requires PostgreSQL >= 13, Redis 5+ (7.x confirmed working)
LABEL_STUDIO_VERSION=20260404.151117-fb-bros-956-f3692362
NGINX_VERSION=1.28.3-alpine3.23
CLOUDFLARED_VERSION=2026.3.0

# ─── PostgreSQL ─────────────────────────────────────────────
POSTGRES_USER=labelstudio
POSTGRES_PASSWORD=<STRONG_RANDOM_PASSWORD>
POSTGRES_DB=labelstudio

# ─── Redis ──────────────────────────────────────────────────
REDIS_PASSWORD=<STRONG_RANDOM_PASSWORD>

# ─── MinIO ──────────────────────────────────────────────────
MINIO_ROOT_USER=<MINIO_ADMIN_USER>
MINIO_ROOT_PASSWORD=<STRONG_RANDOM_PASSWORD_MIN_8_CHARS>
MINIO_BUCKET=label-studio-bucket

# ─── Label Studio ────────────────────────────────────────────
# Public-facing URL (Cloudflare Tunnel domain)
LABEL_STUDIO_HOST=https://label-studio.example.com

# Secret key for Django sessions (generate with: openssl rand -hex 32)
LABEL_STUDIO_SECRET_KEY=<SECRET_KEY>

# Initial superuser (created on first startup)
LABEL_STUDIO_USERNAME=admin@example.com
LABEL_STUDIO_PASSWORD=<STRONG_RANDOM_PASSWORD>

# Disable open registration — require invite link
LABEL_STUDIO_DISABLE_SIGNUP_WITHOUT_LINK=true

# Container-side root for Label Studio's "Local files" storage backend.
# Must be a subpath of /label-studio-data/file (i.e. under LABEL_STUDIO_DATA_DIR).
LABEL_STUDIO_LOCAL_FILES_DOCUMENT_ROOT=/label-studio-data/file

# Pre-provisioned legacy API token for the default admin (FIRST BOOT ONLY).
# Generate: openssl rand -hex 20   ← MUST be exactly 40 hex chars (Token field max_length=40)
#           DO NOT use -hex 32 (64 chars) — it will silently break first-boot user creation.
# Set LABEL_STUDIO_API_KEY below to the same value — sam3-image-backend and sam3-video-backend read that var.
# WARNING: only takes effect on first startup against an empty database.
LABEL_STUDIO_USER_TOKEN=<openssl rand -hex 20>

# ─── Cloudflare Tunnel ───────────────────────────────────────
# Token from: Zero Trust → Access → Tunnels → Create tunnel
# Routes configured in CF dashboard:
#   label-studio.example.com → http://nginx:80
#   minio.example.com        → http://minio:9000  (GET/HEAD WAF only)
CLOUDFLARE_TUNNEL_TOKEN=<YOUR_CF_TUNNEL_TOKEN>

# MinIO external domain (used in presigned URLs — must be publicly resolvable)
MINIO_EXTERNAL_HOST=minio.example.com

# ─── SAM3 ML Backends (ml-backends/sam3-image + sam3-video) ──
# HuggingFace token (required — must accept Meta license at https://huggingface.co/facebook/sam3.1)
HF_TOKEN=<YOUR_HF_TOKEN>

# Label Studio API key used by SAM3 backends to download media via LS API.
# Generate: Settings → Access Tokens → Create
LABEL_STUDIO_API_KEY=<YOUR_LS_API_KEY>

# SAM3 model variant
# Options: facebook/sam3 (SAM3 base) | facebook/sam3.1 (SAM3.1 improved)
SAM3_IMAGE_MODEL_ID=facebook/sam3
SAM3_VIDEO_MODEL_ID=facebook/sam3.1

# SAM3 checkpoint filename on HuggingFace
# facebook/sam3.1 → sam3.1_multiplex.pt  (3.5 GB, image + video shared)
# facebook/sam3   → sam3.pt (3.45 GB)
SAM3_IMAGE_CHECKPOINT_FILENAME=sam3.pt
SAM3_VIDEO_CHECKPOINT_FILENAME=sam3.1_multiplex.pt

# GPU device: cuda (GPU) | cpu (CPU fallback, very slow)
# Requires NVIDIA driver >= 535.x for CUDA 12.6
DEVICE=cuda

# Video backend: max frames to track per prompt
MAX_FRAMES_TO_TRACK=10

# Gunicorn concurrency — applied to both image and video backends.
#
#   ML_WORKERS: number of gunicorn workers (processes).
#     Each worker loads the full model into VRAM (--preload).
#     Rule of thumb: 1 per GPU. For single-GPU machines keep at 1.
#     For dual-GPU nodes: ML_WORKERS=2
#
#   ML_THREADS: threads per worker (gthread worker class).
#     Threads share the same process and model weights — zero extra VRAM cost.
#     Safe to raise on modern CPUs. 8 suits 8-core; 16 for 16+ core servers.
#
ML_WORKERS=1
ML_THREADS=8

# Optional HTTP basic auth for the ML backend API endpoints
ML_BASIC_AUTH_USER=
ML_BASIC_AUTH_PASS=

# ── SAM3 PCS (Promptable Concept Segmentation) — text prompt settings ──────
#
#   SAM3_ENABLE_PCS: enable natural-language text prompts (SAM3 only).
#     Set to false to use geometric-only mode (equivalent to SAM2 behaviour).
#
#   SAM3_CONFIDENCE_THRESHOLD: minimum score for detections from text prompt.
#     Lower = more detections (may include false positives).
#     Higher = fewer, more confident detections. Range [0, 1].
#
#   SAM3_RETURN_ALL_MASKS: when true, all detected objects are returned as
#     separate BrushLabels results. When false (default), only the top-scored
#     detection is returned.
#
SAM3_ENABLE_PCS=true
SAM3_CONFIDENCE_THRESHOLD=0.5
SAM3_RETURN_ALL_MASKS=false

# ── SAM3 Flash Attention 3 (video backend inference speedup) ───────────────
#
#   Requires two conditions:
#     1. Build image with: docker compose build --build-arg ENABLE_FA3=true
#     2. Set SAM3_ENABLE_FA3=true here
#   Compatible with NVIDIA Ampere (A100, RTX 3090) and newer GPUs.
#   CUDA 12.8 wheel is used — tested on CUDA 12.6 containers.
#
SAM3_ENABLE_FA3=false
