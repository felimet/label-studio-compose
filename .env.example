# ============================================================
# Label Studio + MinIO + SAM3 — Environment Variables Template
# Copy this file to .env and fill in all <PLACEHOLDER> values.
# NEVER commit .env to version control.
# ============================================================

# ─── Image Versions ──────────────────────────────────────────
# Pin exact versions to avoid unexpected upgrades.
# Update these when you intentionally want to upgrade a service.
POSTGRES_VERSION=17
REDIS_VERSION=8.6.2
# MinIO: switched to firstfinger/minio:latest (daily build from upstream source with full Admin Console).
# MINIO_VERSION is no longer used — docker-compose.yml pins "firstfinger/minio:latest" directly.
# Reason: MinIO CE removed Admin UI on 2025-05-24; minio/minio Docker Hub stopped after 2025-09-07.
# Ref: https://github.com/Harsh-2002/MinIO, https://hub.docker.com/r/firstfinger/minio
# MINIO_VERSION=RELEASE.2025-04-22T22-12-26Z  # (unused — kept for reference only)
MINIO_VERSION=latest-amd64
MC_VERSION=RELEASE.2025-08-13T08-35-41Z
# Label Studio — requires PostgreSQL >= 13, Redis 5+ (7.x confirmed working)
LABEL_STUDIO_VERSION=latest
NGINX_VERSION=1.28.3-alpine3.23
CLOUDFLARED_VERSION=2026.3.0

# ─── PostgreSQL ─────────────────────────────────────────────
POSTGRES_USER=labelstudio
POSTGRES_PASSWORD=<STRONG_RANDOM_PASSWORD>
POSTGRES_DB=labelstudio

# ─── Redis ──────────────────────────────────────────────────
REDIS_PASSWORD=<STRONG_RANDOM_PASSWORD>

# ─── MinIO ──────────────────────────────────────────────────
# ⚠️  After first deployment, rotate the secret immediately:
#     Admin UI → top-right avatar → Access Keys → Change Password
MINIO_ROOT_USER=<MINIO_ADMIN_USER>
MINIO_ROOT_PASSWORD=<STRONG_RANDOM_PASSWORD_MIN_8_CHARS>
# MinIO bucket(s) for Label Studio data.
# Supports comma-separated names — all listed buckets will be created and
# granted to the LS service account:
#   MINIO_BUCKET=default-bucket,test,another-bucket
# Single bucket (original behaviour) still works.
MINIO_BUCKET=default-bucket

# Label Studio service account — least-privilege access key scoped to MINIO_BUCKET only.
# Use these credentials (not root) when configuring Label Studio Cloud Storage (S3) in the UI.
# Provisioned automatically by: make init-minio
# Or create manually: Admin UI → Identity → Users → Create User, log in as that user
#   → top-right avatar → Access Keys → Create Access Key
# Update MINIO_LS_SECRET_KEY here and in LS Cloud Storage settings.
# Generate: openssl rand -hex 10  (access key ID, ≥3 chars)
#           openssl rand -hex 20  (secret key, ≥8 chars)
MINIO_LS_ACCESS_ID=<LS_ACCESS_KEY>
MINIO_LS_SECRET_KEY=<STRONG_RANDOM_SECRET_MIN_8_CHARS>

# Bucket quota in GiB. Prevents unbounded storage growth. Leave empty to disable.
MINIO_BUCKET_QUOTA_GB=

# SSE-S3 bucket encryption master key (no external KES required).
# Format: <key-name>:<base64-encoded-32-byte-key>
# Generate: printf 'minio-sse-key:'; openssl rand -base64 32
# Leave empty to disable SSE-S3.
MINIO_KMS_SECRET_KEY=

# ─── Label Studio ────────────────────────────────────────────
# Public-facing URL (Cloudflare Tunnel domain)
LABEL_STUDIO_HOST=https://label-studio.example.com

# Secret key for Django sessions (generate with: openssl rand -hex 32)
LABEL_STUDIO_SECRET_KEY=<SECRET_KEY>

# Initial superuser (created on first startup)
LABEL_STUDIO_USERNAME=admin@example.com
LABEL_STUDIO_PASSWORD=<STRONG_RANDOM_PASSWORD>

# Disable open registration — require invite link
LABEL_STUDIO_DISABLE_SIGNUP_WITHOUT_LINK=true

# Container-side root for Label Studio's "Local files" storage backend.
# This is the path INSIDE the container (volume mount: ./label-studio-data → /label-studio/data).
# Must be a subpath of /label-studio/data.
LABEL_STUDIO_LOCAL_FILES_DOCUMENT_ROOT=/label-studio/data/file

# Pre-provisioned legacy API token for the default admin (FIRST BOOT ONLY).
# Generate: openssl rand -hex 20   ← MUST be exactly 40 hex chars (Token field max_length=40)
#           DO NOT use -hex 32 (64 chars) — it will silently break first-boot user creation.
# Set LABEL_STUDIO_API_KEY below to the same value — sam3-image-backend and sam3-video-backend read that var.
# WARNING: only takes effect on first startup against an empty database.
LABEL_STUDIO_USER_TOKEN=<openssl rand -hex 20>

# ─── Cloudflare Tunnel ───────────────────────────────────────
# Token from: Zero Trust → Access → Tunnels → Create tunnel
# Routes configured in CF dashboard:
#   label-studio.example.com → http://nginx:80
#   minio.example.com        → http://minio:9000  (GET/HEAD WAF only)
CLOUDFLARE_TUNNEL_TOKEN=<YOUR_CF_TUNNEL_TOKEN>

# MinIO external domain (used in presigned URLs — must be publicly resolvable)
MINIO_EXTERNAL_HOST=minio.example.com
# MinIO console external domain (Cloudflare Tunnel route → minio:9001)
# Must differ from MINIO_EXTERNAL_HOST; used by MINIO_BROWSER_REDIRECT_URL
MINIO_CONSOLE_HOST=minio-console-test.example.com

# ─── SAM3 ML Backends ────────────────────────────────────────
# ML backend variables are managed in a separate file.
# Copy .env.ml.example → .env.ml and fill in the values there.
# See .env.ml.example for full documentation.
