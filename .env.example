# ============================================================
# Core Stack Environment Template
# Scope: docker-compose.yml + docker-compose.override.yml
# Services: redis, minio, label-studio, nginx, cloudflared
#
# Usage:
#   cp .env.example .env
#   # Fill all <PLACEHOLDER> values
#
# Notes:
# - ML variables belong to .env.ml.example
# - Supabase standalone management variables belong to .env.supabase.example
# - Supabase sample-mode variables belong to .env.supabase.sample.template
# - Developer tool variables belong to .env.tools.example
# ============================================================

# ─── Image Versions ──────────────────────────────────────────
REDIS_VERSION=8.6.2
MINIO_VERSION=latest-amd64
MC_VERSION=RELEASE.2025-08-13T08-35-41Z
LABEL_STUDIO_VERSION=latest
NGINX_VERSION=1.28.3-alpine3.23
CLOUDFLARED_VERSION=2026.3.0

# ─── PostgreSQL ─────────────────────────────────────────────
# Shared database credentials for Label Studio and Supabase standalone.
# Where used:
# - docker-compose.yml -> label-studio POSTGRE_PASSWORD
# - docker-compose.supabase.yml -> db/auth/rest/storage/meta/supavisor
# Generate POSTGRES_PASSWORD:
#   openssl rand -hex 32
# Common pitfall:
# - If Label Studio points to Supabase (LS_POSTGRE_HOST=supavisor),
#   POSTGRES_PASSWORD must match .env.supabase POSTGRES_PASSWORD.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=<STRONG_RANDOM_PASSWORD>
POSTGRES_DB=postgres

# ─── Redis ──────────────────────────────────────────────────
# Redis password for task queue/cache.
# Generate:
#   openssl rand -hex 32
REDIS_PASSWORD=<STRONG_RANDOM_PASSWORD>

# ─── MinIO ──────────────────────────────────────────────────
# MinIO root admin account.
# Where used:
# - MinIO Console/Admin UI login
# - minio-init bootstrap (bucket/policy/service-account provisioning)
# Generate root password:
#   openssl rand -hex 32
# Common pitfall:
# - Do NOT use root credentials in Label Studio S3 storage settings.
MINIO_ROOT_USER=<MINIO_ADMIN_USER>
MINIO_ROOT_PASSWORD=<STRONG_RANDOM_PASSWORD_MIN_8_CHARS>

# MinIO bucket for Label Studio data - can be any valid bucket name.
# It will be created by minio-init at startup if missing.
# You can also create buckets manually from MinIO Admin UI.
MINIO_BUCKET=default-bucket

# MinIO server-level CORS allowlist for browser uploads.
# Use your Label Studio origin (comma-separated for multiple origins).
# Avoid '*' in production.
MINIO_API_CORS_ALLOW_ORIGIN=https://label-studio.example.com

# Anonymous bucket download policy applied by minio-init.
# false: private bucket (recommended)
# true:  anonymous GET download enabled
MINIO_ANONYMOUS_DOWNLOAD=false

# Label Studio service account - least-privilege access key scoped to MINIO_BUCKET only.
# Created by minio-init on first run.
# Use these credentials (not root) when configuring Label Studio Cloud Storage (S3) in UI.
# If needed, you can create additional users/keys in MinIO Admin UI -> Access Keys.
# Generate:
#   openssl rand -hex 10  (access key id, >= 3 chars)
#   openssl rand -hex 20  (secret key, >= 8 chars)
MINIO_LS_ACCESS_ID=<LS_ACCESS_KEY>
MINIO_LS_SECRET_KEY=<STRONG_RANDOM_SECRET_MIN_8_CHARS>

# Optional bucket quota (GiB). Leave empty to disable.
MINIO_BUCKET_QUOTA_GB=

# Optional SSE-S3 master key. Leave empty to disable.
# Format: <key-name>:<base64-encoded-32-byte-key>
# Generate:
#   printf 'minio-sse-key:'; openssl rand -base64 32
# Common pitfall:
# - Keep full value on one line (no line breaks/spaces).
MINIO_KMS_SECRET_KEY=

# ─── Label Studio ────────────────────────────────────────────
# Label Studio DB target (default: Supabase standalone pooler on shared internal network)
# Where used:
# - docker-compose.yml -> label-studio POSTGRE_* env vars
# When to change:
# - Use supavisor (default) for Supabase-managed DB
# - LS_POSTGRE_NAME / LS_POSTGRE_USER can be customized, but target DB/role must already exist
#   in Supabase postgres and have connect/schema/table permissions.
# Common pitfall:
# - Setting custom name/user here before creating DB role grants causes startup auth failures.
LS_POSTGRE_HOST=supavisor
LS_POSTGRE_PORT=5432
LS_POSTGRE_NAME=postgres
# postgres.<POOLER_TENANT_ID> same as .env.supabase POOLER_TENANT_ID when using supavisor.
LS_POSTGRE_USER=postgres.<POOLER_TENANT_ID>

# IMPORTANT: keep POSTGRES_PASSWORD in this file equal to .env.supabase POSTGRES_PASSWORD
# when Label Studio is connected to Supabase standalone.
# Public URL for browser access (also used for CSRF trusted origin).
# Common pitfall:
# - Must include scheme (https://...) and no trailing spaces.
LABEL_STUDIO_HOST=https://label-studio.example.com

# Django secret key for Label Studio.
# Generate:
#   openssl rand -hex 32
LABEL_STUDIO_SECRET_KEY=<SECRET_KEY>

# Initial admin account (applied on first boot with empty DB).
LABEL_STUDIO_USERNAME=admin@example.com
LABEL_STUDIO_PASSWORD=<STRONG_RANDOM_PASSWORD>
LABEL_STUDIO_DISABLE_SIGNUP_WITHOUT_LINK=true
LABEL_STUDIO_LOCAL_FILES_DOCUMENT_ROOT=/label-studio/data/file

# First boot only; MUST be <= 40 chars.
# Generate exactly 40 hex chars:
#   openssl rand -hex 20
# Common pitfall:
# - If DB already initialized, changing this value has no effect.
LABEL_STUDIO_USER_TOKEN=<openssl rand -hex 20>

# ─── Cloudflare Tunnel ───────────────────────────────────────
# Tunnel token from Cloudflare Zero Trust -> Networks -> Tunnels.
# Common pitfall:
# - Invalid/expired token causes cloudflared restart loop.
CLOUDFLARE_TUNNEL_TOKEN=<YOUR_CF_TUNNEL_TOKEN>

# Core routes
# Public host used in presigned URL generation (must match your tunnel hostname).
MINIO_EXTERNAL_HOST=minio-api.example.com
# Public host for MinIO Console redirect target.
MINIO_CONSOLE_HOST=minio-console.example.com

# Optional overlay routes (Supabase Studio/Meta, RedisInsight)
# are configured directly in Cloudflare Zero Trust -> Tunnel -> Public Hostnames.
# Do not define them as env vars.

