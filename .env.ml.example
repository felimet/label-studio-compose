# ============================================================
# SAM3 ML Backends — Environment Variables
# Copy this file to .env.ml and fill in all <PLACEHOLDER> values.
# NEVER commit .env.ml to version control.
#
# Variables use container-expected names — no mapping in docker-compose.ml.yml.
# Loaded via `env_file: .env.ml` in docker-compose.ml.yml.
# ============================================================

# ─── Label Studio Connection ─────────────────────────────────
# API key used by SAM3 backends to call the Label Studio API.
# ⚠ MUST use Legacy Token (NOT Personal Access Token).
#   ML backend SDK sends "Authorization: Token <key>" — only Legacy Token
#   matches this format. PAT uses JWT Bearer and will result in 401.
#
# How to get (after first boot):
#   1. make up
#   2. Login to Label Studio UI
#   3. Avatar (top-right) → Account & Settings → Legacy Token → Copy
# Where used:
#   - sam3-image-backend / sam3-video-backend API calls to Label Studio
#   - sam21-image-backend / sam21-video-backend API calls
#
# NOTE: This value should match LABEL_STUDIO_USER_TOKEN in .env
#   (both refer to the same Legacy Token).
# DO NOT paste Personal Access Token or JWT Bearer token here.
# Typical failure symptom when wrong token is used: 401 Unauthorized on task fetch/predict.
#
LABEL_STUDIO_API_KEY=<YOUR_LS_API_KEY>

# ─── HuggingFace ─────────────────────────────────────────────
# Required to download gated SAM3 model weights.
#   1. Accept Meta license: https://huggingface.co/facebook/sam3.1
#   2. Generate token: https://huggingface.co/settings/tokens
# Recommendation: read-only token is sufficient for model download.
# Common pitfall:
#   - Token accepted but model download still fails if license was not accepted.
HF_TOKEN=<YOUR_HF_TOKEN>

# ─── SAM3 Model ──────────────────────────────────────────────
# Image and video backends can use different checkpoints.
# Per-backend vars take priority; shared fallback used when per-backend not set.
#
# Available checkpoints:
#   facebook/sam3   + sam3.pt             (~3.45 GB, base)
#   facebook/sam3.1 + sam3.1_multiplex.pt (~3.5 GB,  improved — recommended)
#
# Image backend — uses sam3.pt (build_sam3_image_model, no SAM3.1 image variant exists)
SAM3_IMAGE_MODEL_ID=facebook/sam3
SAM3_IMAGE_CHECKPOINT_FILENAME=sam3.pt

# Video backend — uses sam3.1_multiplex.pt (build_sam3_multiplex_video_predictor)
SAM3_VIDEO_MODEL_ID=facebook/sam3.1
SAM3_VIDEO_CHECKPOINT_FILENAME=sam3.1_multiplex.pt

# GPU device: cuda (GPU) | cpu (CPU fallback, very slow)
# Where used:
#   - startup script selects torch device for model loading/inference
# Requires NVIDIA driver >= 535.x (CUDA 12.6).
# Recommended: Turing sm_75+ (RTX 20xx / T4) or newer for full support.
# Pascal (GTX 10xx, sm_61): image backend confirmed working; video backend (sam3.1)
#   may fail at inference — switch to SAM3_VIDEO_CHECKPOINT_FILENAME=sam3.pt as workaround.
# Volta (sm_70/72): same as Pascal.
DEVICE=cuda

# ─── GPU Assignment ───────────────────────────────────────────
# Pin each backend to one or more physical GPUs (nvidia-smi index).
# Useful when two or more GPUs are available and you want to avoid VRAM contention.
# Leave empty to expose all GPUs to both containers (default — safe for single-GPU).
#
#   Single-GPU (one card shared by both services):
#     SAM3_IMAGE_GPU_INDEX=          SAM3_IMAGE_WORKERS=1
#     SAM3_VIDEO_GPU_INDEX=          SAM3_VIDEO_WORKERS=1
#
#   Dual-GPU (each service on its own GPU):
#     SAM3_IMAGE_GPU_INDEX=0         SAM3_IMAGE_WORKERS=1
#     SAM3_VIDEO_GPU_INDEX=1         SAM3_VIDEO_WORKERS=1
#
#   Image on GPU 0, video spread across GPU 1+2+3:
#     SAM3_IMAGE_GPU_INDEX=0         SAM3_IMAGE_WORKERS=1
#     SAM3_VIDEO_GPU_INDEX=1,2,3     SAM3_VIDEO_WORKERS=3
#     gunicorn post_fork pins worker i to gpus[i-1]; each worker sees cuda:0 internally
SAM3_IMAGE_GPU_INDEX=0
SAM3_VIDEO_GPU_INDEX=1

# ─── Performance ─────────────────────────────────────────────
# SAM3_IMAGE_WORKERS / SAM3_VIDEO_WORKERS: gunicorn worker processes per service.
#   Each worker loads the full model independently → each occupies VRAM on its GPU.
#   Set equal to the number of GPUs in the corresponding SAM3_*_GPU_INDEX list.
#   Single GPU (or empty index): always use 1 — extra workers pile onto the same GPU.
# Common pitfall:
#   - workers > available GPUs usually increases OOM risk instead of throughput.
SAM3_IMAGE_WORKERS=1
SAM3_VIDEO_WORKERS=1

# GPU_IDLE_TIMEOUT_SECS: seconds of inactivity before model is unloaded from VRAM.
#   Default: 3600 (1 hour). Set lower to reclaim VRAM faster when idle.
#   The watchdog checks every 60 s; actual release may lag up to 60 s.
GPU_IDLE_TIMEOUT_SECS=3600

# TORCH_DTYPE: override automatic precision detection.
#   Auto-detection (recommended — leave empty):
#     sm_80+ Ampere  → bfloat16 autocast + TF32
#     sm_75–79 Turing → bfloat16 autocast
#     < sm_75 Pascal/Volta → bfloat16 autocast + WARNING (model loads, inference attempted)
#   Override only when needed:
#     TORCH_DTYPE=fp16   → force float16 autocast
#     TORCH_DTYPE=bf16   → force bfloat16 autocast
#   Leave empty to use auto-detection.
TORCH_DTYPE=

# THREADS: threads per worker (gthread). Share the same model — zero extra VRAM.
#   8 suits 8-core CPUs; 16 for 16+ core servers.
THREADS=8

# Video backend: max frames to track per prompt
# Also controls how many frames are extracted to the temp folder (memory budget).
# Lower = less VRAM. Recommended: 5–10.
MAX_FRAMES_TO_TRACK=10

# Video backend: cap long side of extracted frames (pixels). 0 = no resize.
# SAM3 ViT attention is O(spatial_tokens²) — halving resolution cuts VRAM ~4×.
# 1080p → 1024 saves ~3× VRAM per frame. Recommended: 1024.
MAX_FRAME_LONG_SIDE=1024

# ─── PCS (Promptable Concept Segmentation) ───────────────────
# SAM3's open-vocabulary text prompt: type a label name to segment matching objects.
#   SAM3_ENABLE_PCS=false  → geometry-only mode (same behaviour as SAM2)
#   SAM3_CONFIDENCE_THRESHOLD: min detection score [0–1]; lower = more results
#   SAM3_RETURN_ALL_MASKS: true = all instances; false = top-scored only
SAM3_ENABLE_PCS=true
SAM3_CONFIDENCE_THRESHOLD=0.5
SAM3_RETURN_ALL_MASKS=false

# ─── Flash Attention 3 (video backend speedup) ───────────────
# Requires TWO steps:
#   1. Build with: docker compose build --build-arg ENABLE_FA3=true sam3-video-backend
#   2. Set SAM3_ENABLE_FA3=true here
# Compatible with NVIDIA Hopper (H100/H800) only.
# flash_attn_interface is NOT available via pip — requires custom build.
# Leave false unless you have Hopper hardware and a custom build.
SAM3_ENABLE_FA3=false

# ─── SAM2.1 Backends ─────────────────────────────────────────
# Both backends (sam21-image, sam21-video) share the same model settings.
#
# Model settings (recommended):
#   MODEL_CONFIG     — SAM2 config YAML file (relative or absolute path)
#   MODEL_CHECKPOINT — checkpoint filename (stored in /data/models) or absolute path
#   Both must be set to take effect.
#
#   sam2.1_hiera_tiny.pt      → sam2.1_hiera_t.yaml  (~38M)  fastest, lowest VRAM
#   sam2.1_hiera_small.pt     → sam2.1_hiera_s.yaml  (~46M)
#   sam2.1_hiera_base_plus.pt → sam2.1_hiera_b+.yaml (~80M)
#   sam2.1_hiera_large.pt     → sam2.1_hiera_l.yaml  (~224M) most accurate
#
# Example (use built-in large model):
#   MODEL_CONFIG=configs/sam2.1/sam2.1_hiera_l.yaml
#   MODEL_CHECKPOINT=sam2.1_hiera_large.pt
#
# Example (use custom model):
#   MODEL_CONFIG=/data/models/my_custom.yaml
#   MODEL_CHECKPOINT=/data/models/my_custom.pt
MODEL_CONFIG=configs/sam2.1/sam2.1_hiera_l.yaml
MODEL_CHECKPOINT=sam2.1_hiera_large.pt

# GPU assignment (same as SAM3; leave empty to expose all GPUs)
SAM21_IMAGE_GPU_INDEX=0
SAM21_VIDEO_GPU_INDEX=0

# gunicorn workers (each worker loads a separate model copy in VRAM; recommended = GPU count)
SAM21_IMAGE_WORKERS=1
SAM21_VIDEO_WORKERS=1

# ─── Logging ─────────────────────────────────────────────────
LOG_LEVEL=INFO

# ─── Optional Basic Auth ─────────────────────────────────────
# Protect ML backend API with HTTP Basic Auth (leave empty to disable).
# Safe to leave empty — backends are on the internal Docker network.
BASIC_AUTH_USER=
BASIC_AUTH_PASS=
