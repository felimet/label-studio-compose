# ============================================================
# Supabase Environment Template (aligned to supabase/supabase/docker)
# MODE: Sample only (used with docker-compose.yml + docker-compose.supabase.sample.yml)
# Do NOT use this file for standalone Supabase stack.
# Scope in this repository:
#   - default lane: studio + postgres-meta
#   - optional profile `supabase-s3`: storage-api + imgproxy (MinIO S3 backend)
#
# Usage:
#   cp .env.supabase.sample.template .env.supabase.sample
#
# Variable semantics:
# - VAR=value        -> pass literal value to container
# - VAR=             -> empty string; with ${VAR:-default} this is treated as "use default"
# - # VAR=value      -> variable undefined (compose fallback/default may apply)
# - ${VAR:?message}  -> required by compose; unset OR empty value causes startup failure
# ============================================================

############
# Sample-mode ports/bind (this repository)
############
SUPABASE_STUDIO_BIND_ADDRESS=127.0.0.1
SUPABASE_STUDIO_PORT=18091
SUPABASE_META_BIND_ADDRESS=127.0.0.1
SUPABASE_META_PORT=18087
SUPABASE_META_CONTAINER_PORT=8080
SUPABASE_META_HOST=0.0.0.0

############
# Secrets (required for studio/meta)
############
# Required in sample mode:
# - POSTGRES_PASSWORD must match .env POSTGRES_PASSWORD when sharing the same DB credentials.
# - PG_META_CRYPTO_KEY must be >= 32 chars.
# Generate:
#   openssl rand -hex 32
# Common pitfall:
# - Mismatched POSTGRES_PASSWORD between .env and .env.supabase.sample causes postgres-meta auth failures.
POSTGRES_PASSWORD=<STRONG_RANDOM_PASSWORD>
PG_META_CRYPTO_KEY=<AT_LEAST_32_CHARS>

# Legacy symmetric HS256 key + legacy API keys
# In sample mode these can stay empty if you only need studio + postgres-meta.
# If you later enable auth/gateway-related services, set all three consistently.
JWT_SECRET=
ANON_KEY=
SERVICE_ROLE_KEY=

# Optional asymmetric key pair / opaque API keys (reserved for full Supabase stack)
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
JWT_KEYS=
JWT_JWKS=

# Optional dashboard/basic auth (reserved for kong/studio full stack scenarios)
DASHBOARD_USERNAME=supabase
DASHBOARD_PASSWORD=

# Reserved for Realtime/Supavisor in full stack mode
SECRET_KEY_BASE=
VAULT_ENC_KEY=

# Optional analytics tokens
# Generate when analytics/vector services are enabled:
#   openssl rand -hex 32
# Keep public/private values different for easier incident isolation.
LOGFLARE_PUBLIC_ACCESS_TOKEN=
LOGFLARE_PRIVATE_ACCESS_TOKEN=

# Optional Storage S3 protocol keys (client-facing S3 endpoint).
# Used by external S3 clients hitting Supabase Storage S3 protocol endpoint.
# Not used for Storage service -> MinIO backend connection.
S3_PROTOCOL_ACCESS_KEY_ID=
S3_PROTOCOL_ACCESS_KEY_SECRET=

############
# URLs
############
SUPABASE_PUBLIC_URL=http://localhost:18090
API_EXTERNAL_URL=http://localhost:18090
SUPABASE_URL=http://nginx:80
LOGFLARE_URL=http://analytics:4000

# If you change SUPABASE_META_CONTAINER_PORT, update Cloudflare Tunnel
# service target accordingly (http://supabase-meta:<port>).

############
# Database (official key names)
############
# By default, these come from core `.env` to avoid accidental overrides.
# Uncomment only if Supabase sample mode must target a different DB endpoint.
# POSTGRES_HOST=pg-db
# POSTGRES_USER=labelstudio
# POSTGRES_DB=labelstudio
# POSTGRES_PORT=5432

# postgres-meta runtime tuning
PG_META_DB_SSL_MODE=disable
PG_META_DB_SSL_ROOT_CERT=
PG_CONN_TIMEOUT_SECS=15
PG_QUERY_TIMEOUT_SECS=55
PG_META_MAX_RESULT_SIZE_MB=2048
PG_META_MAX_BODY_LIMIT_MB=3
PG_META_REQ_HEADER=request-id

############
# Supavisor (reserved for full stack)
############
POOLER_PROXY_PORT_TRANSACTION=6543
POOLER_DEFAULT_POOL_SIZE=20
POOLER_MAX_CLIENT_CONN=100
POOLER_TENANT_ID=
POOLER_DB_POOL_SIZE=5

############
# Studio
############
STUDIO_DEFAULT_ORGANIZATION=Default Organization
STUDIO_DEFAULT_PROJECT=Default Project
OPENAI_API_KEY=
NEXT_PUBLIC_ENABLE_LOGS=false
NEXT_ANALYTICS_BACKEND_PROVIDER=postgres

############
# Auth (reserved for full stack)
############
SITE_URL=http://localhost:3000
ADDITIONAL_REDIRECT_URLS=
JWT_EXPIRY=3600
DISABLE_SIGNUP=false

MAILER_URLPATHS_CONFIRMATION="/auth/v1/verify"
MAILER_URLPATHS_INVITE="/auth/v1/verify"
MAILER_URLPATHS_RECOVERY="/auth/v1/verify"
MAILER_URLPATHS_EMAIL_CHANGE="/auth/v1/verify"

ENABLE_EMAIL_SIGNUP=true
ENABLE_EMAIL_AUTOCONFIRM=false
SMTP_ADMIN_EMAIL=admin@example.com
SMTP_HOST=supabase-mail
SMTP_PORT=2500
SMTP_USER=
SMTP_PASS=
SMTP_SENDER_NAME=
ENABLE_ANONYMOUS_USERS=false

ENABLE_PHONE_SIGNUP=true
ENABLE_PHONE_AUTOCONFIRM=true

# OAuth/SMS/MFA/SAML options are optional by design and should stay commented
# unless those providers are explicitly enabled in compose service definitions.

############
# Storage (reserved for full stack)
############
# The optional `supabase-s3` profile uses MinIO as S3 backend.
# IMPORTANT:
# - Credentials are read from .env: MINIO_LS_ACCESS_ID / MINIO_LS_SECRET_KEY
# - Run `make init-minio` first to provision bucket + service account.
# - This profile does not publish host ports (internal only: storage:5000, imgproxy:5001).

# Optional image overrides
SUPABASE_STORAGE_IMAGE=supabase/storage-api:v1.48.26
SUPABASE_IMGPROXY_IMAGE=darthsim/imgproxy:v3.30.1

# Optional internal service settings
SUPABASE_STORAGE_FILE_SIZE_LIMIT=52428800
SUPABASE_STORAGE_ENABLE_IMAGE_TRANSFORMATION=true
# Requires a reachable PostgREST endpoint.
# For full Supabase stack, this is usually: http://supabase-rest:3000
SUPABASE_STORAGE_POSTGREST_URL=http://supabase-rest:3000
# Leave empty to let compose build DATABASE_URL from POSTGRES_*.
SUPABASE_STORAGE_DATABASE_URL=

# S3 backend settings (adapted for this project MinIO)
SUPABASE_STORAGE_BACKEND=s3
# Storage bucket name for sample mode (can be any valid bucket name).
# Bucket is provisioned by minio-init when MINIO_BUCKET matches this value,
# or can be created manually in MinIO Admin UI.
SUPABASE_STORAGE_BUCKET=default-bucket
SUPABASE_STORAGE_S3_ENDPOINT=http://minio:9000
SUPABASE_STORAGE_S3_PROTOCOL=http
SUPABASE_STORAGE_S3_FORCE_PATH_STYLE=true
# Region label for S3 client compatibility.
# For MinIO, this is typically metadata and can stay ap-east-1 unless your clients require another value.
SUPABASE_STORAGE_REGION=ap-east-1
SUPABASE_STORAGE_TENANT_ID=label-studio

# Backend credentials come from core .env:
#   MINIO_LS_ACCESS_ID / MINIO_LS_SECRET_KEY

############
# Edge Functions / API / Analytics (reserved for full stack)
############
FUNCTIONS_VERIFY_JWT=false
PGRST_DB_SCHEMAS=public,storage,graphql_public
PGRST_DB_MAX_ROWS=1000
PGRST_DB_EXTRA_SEARCH_PATH=public
DOCKER_SOCKET_LOCATION=/var/run/docker.sock
GOOGLE_PROJECT_ID=
GOOGLE_PROJECT_NUMBER=

############
# API Gateway / imgproxy / TLS proxy (reserved for full stack)
############
KONG_HTTP_PORT=8000
KONG_HTTPS_PORT=8443
ANON_KEY_ASYMMETRIC=
SERVICE_ROLE_KEY_ASYMMETRIC=
IMGPROXY_AUTO_WEBP=true
PROXY_DOMAIN=
CERTBOT_EMAIL=
